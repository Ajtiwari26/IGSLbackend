# Server Port
PORT=5001

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/igsl

# JWT signing secret
JWT_SECRET=your_jwt_signing_secret_here

# Third-party mocks (mParivahan, Razorpay, SIM tracking)
# Set to 'false' to use real integrated APIs
MOCK_MODE=true

# Database Bypass Toggle (For local integration testing before DB connection is supplied)
MOCK_DB=false

# Allowed Client Origins (Comma separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:19006,http://localhost:5173

# Logging Level
LOG_LEVEL=INFO
NODE_ENV=development

# Razorpay Test Keys
RAZORPAY_KEY_ID=your_razorpay_key_id_here
RAZORPAY_KEY_SECRET=your_razorpay_key_secret_here
